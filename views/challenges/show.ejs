<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="/images/logo.png" type="image/x-icon">
    <link rel="stylesheet" href="/stylesheets/style.css">
    <title>Show Challenge</title>
</head>
<body>
    <%- include('../partials/nav.ejs') %>
    <h1>Display Challenge</h1>
     <main class="show-page">
        <article class="challenge-card show-card">
            <h1><%= foundChallenge.title %></h1>

            <iframe
                src="<%= foundChallenge.videoUrl %>"
                title="<%= foundChallenge.title %>"
                allowfullscreen>
            </iframe>

            <div class="challenge-details">
                <p><strong>Game:</strong> <%= foundChallenge.game %></p>
                <p><strong>Genre:</strong> <%= foundChallenge.genre %></p>
                <p><strong>Platform:</strong> <%= foundChallenge.platform %></p>
                <p><strong>Rules:</strong> <%= foundChallenge.rules %></p>
                <p>
                    <strong>Uploaded by:</strong>
                    <%= foundChallenge.owner.username %>
                </p>
            </div>

            <% if (user && foundChallenge.owner._id.equals(user._id)) { %>
                <div class="owner-controls">
                    <a
                        class="button-link"
                        href="/challenges/<%= foundChallenge._id %>/edit"
                    >
                        Edit Record
                    </a>

                    <form
                        action="/challenges/<%= foundChallenge._id %>?_method=DELETE"
                        method="POST"
                    >
                        <button type="submit">Delete Record</button>
                    </form>
                </div>
            <% } %>
        </article>

        <section class="favorites-section">
            <h2>Favorites</h2>

            <% if (foundChallenge.favoritedByUsers.length === 0) { %>
                <p>No favorites on this post.</p>
            <% } else if (foundChallenge.favoritedByUsers.length === 1) { %>
                <p>Favorited by 1 person.</p>
            <% } else { %>
                <p>
                    Favorited by
                    <%= foundChallenge.favoritedByUsers.length %>
                    people.
                </p>
            <% } %>

            <% if (user) { %>
                <% if (userHasFavorited) { %>
                    <form
                        action="/challenges/<%= foundChallenge._id %>/favorited?_method=DELETE"
                        method="POST"
                    >
                        <button type="submit">Remove Favorite</button>
                    </form>
                <% } else { %>
                    <form
                        action="/challenges/<%= foundChallenge._id %>/favorited"
                        method="POST"
                    >
                        <button type="submit">Favorite</button>
                    </form>
                <% } %>
            <% } else { %>
                <p>Sign in to favorite this challenge.</p>
            <% } %>
        </section>

        <section class="comments-section">
            <h2>Comments</h2>

            <% if (foundChallenge.comments.length === 0) { %>
                <p>No comments posted.</p>
            <% } %>

            <div class="comments-list">
                <% foundChallenge.comments.forEach((comment) => { %>
                    <article class="comment">
                        <p><%= comment.content %></p>

                        <p class="comment-author">
                            Posted by: <%= comment.author.username %>
                        </p>

                        <% if (user && comment.author._id.equals(user._id)) { %>
                            <form
                                action="/challenges/<%= foundChallenge._id %>/comments/<%= comment._id %>?_method=DELETE"
                                method="POST"
                            >
                                <button type="submit">Delete Comment</button>
                            </form>
                        <% } %>
                    </article>
                <% }) %>
            </div>

            <% if (user) { %>
                <form
                    class="comment-form"
                    action="/challenges/<%= foundChallenge._id %>/comments"
                    method="POST"
                >
                    <h2>Share a Comment</h2>

                    <textarea
                        name="content"
                        rows="5"
                        required
                    ></textarea>

                    <button type="submit">Post Comment</button>
                </form>
            <% } else { %>
                <p>Sign in to leave a comment.</p>
            <% } %>
        </section>
    </main>
</body>
</body>
</html>
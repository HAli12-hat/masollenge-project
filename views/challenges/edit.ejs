<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Edit Your Record</h1>
    <form action="/challenges/<%=foundChallenge._id%>?_method=PUT" method="POST">
        <label for="title">Title:</label>
        <input type="text" name="title" value="<%=foundChallenge.title%>" required>

        <label for="game">Game:</label>
        <select id="game" name="game"  required>
            <option value="<%=foundChallenge.game%>"><%=foundChallenge.game%></option>
            <option value="Devil May Cry 5">Devil May Cry 5</option>
            <option value="Ninja Gaiden Black">Ninja Gaiden Black</option>
            <option value="A Hat in Time">A Hat in Time</option>
            <option value="Lost Judgement">Lost Judgement</option>
        </select>

        <label for="genre">Genre:</label>
        <select id="genre" name="genre" required>
            <option value="<%=foundChallenge.genre%>"><%=foundChallenge.genre%></option>
            <option value="action">Action</option>
            <option value="hack-and-slash">Hack and Slash</option>
            <option value="platformer">Platformer</option>
            <option value="beat-em-up">Beat em up</option>
            <option value="soulsborne">Soulsborne</option>
        </select>
        <br><br>
        <label for="rules">Rules:</label>
        <input type="text" name="rules" value="<%=foundChallenge.rules%>" required>

        <label for="videoUrl">Video URL:</label>
        <input type="url" name="videoUrl" placeholder="https://www.youtube.com/watch?v=..."  value="<%=foundChallenge.videoUrl%>" required>
        <br><br>
        <label for="platform">Platform:</label>
        <select id="platform" name="platform" required>
            <option value="<%=foundChallenge.platform%>"><%=foundChallenge.platform%></option>
            <option value="pc">PC</option>
            <option value="switch">Nintendo Switch</option>
            <option value="ps5">PS5</option>
            <option value="xbox">Xbox</option>
        </select>

        <button type="submit">Edit Record</button>
    </form>
</body>
</html>